<mvc:View xmlns:core="sap.ui.core" controllerName="student.com.sap.training.advancedsapui5.employeedirectory.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
    <Panel headerText="Select an Employee from the list " expandable="true" expanded="true">
        <content>
        <SearchField placeholder="Search by name..."
    liveChange=".onSearch"/>
    <SearchField placeholder="Search by department..."
    liveChange=".onSearch2"/>
    <Select id="sortlist" change=".onSort">
        <items>
        <core:Item key="" text="Sort by..." />
        <core:Item key="name" text="Sort by Name" />
        <core:Item key="department" text="Sort by Department" />
        </items> 
           </Select>
        <List id="emplist" headerText="Emplyees" items="{emp>/employees}" mode="SingleSelectMaster" selectionChange=".onEmployeeSelect">
        <StandardListItem id="employeeItem" title="{emp>name}" description="{emp>department}" type="Active"/>

        </List>
      
        <Table class="employeeDetails" id="empTable" >
        <columns>
            <Column><Text text="ID" /></Column>
            <Column><Text text="Name"/></Column>
            <Column><Text text="Department"/></Column>
            <Column><Text text="Email"/></Column>
            <Column><Text text="Salary"/></Column>
        </columns>
        <ColumnListItem> 
        <cells>
            <Text text="{emp>/selectedEmployee/id} "/>
            <Text text="{emp>/selectedEmployee/name}"/>
            <Text text="{emp>/selectedEmployee/department}"/>
            <Text text="{emp>/selectedEmployee/email}"/>
            <Text text="{emp>/selectedEmployee/salary}"/>
        </cells>
        </ColumnListItem>
        </Table>
        </content>



    </Panel>
    <Panel headerText="Create new Employee" expandable="true" expanded="true">
    <content>
    <VBox class="sapUiSmallMargin">
    <Title text="add Employee"/>
    <Input placeholder="Enter name" value="{emp>/newEmployee/name}"/>
    <Input placeholder="Enter department" value="{emp>/newEmployee/department}"/>
    <Input placeholder="Enter email" value="{emp>/newEmployee/email}"/>
    <Input placeholder="Enter salary" value="{emp>/newEmployee/salary}"/>
    <Button text="Add Employee" press=".onAddEmployee"/>
    </VBox>
    </content>
    
    </Panel>

    </Page>
</mvc:View>