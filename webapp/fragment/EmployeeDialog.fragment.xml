<core:FragmentDefinition
xmlns ="sap.m"
xmlns:core="sap.ui.core"
>
<Dialog title="Employee Details">
    <Text text = "{emp>/selectedEmployee/name}"/>
    <beginButton>
    <Button text="delete" press=".onDeleteEmployee"/>
    
    </beginButton>
   
    <endButton>
    <Button text="close" press=".onCloseDialog"/>
    </endButton>
    <Button text="edit" press=".onEditEmployee"/>
   

</Dialog>
</core:FragmentDefinition>